---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <section id="features" class="flex min-h-screen items-center pt-24">
    <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="font-mono text-sm uppercase tracking-widest text-star-400">
        Features
      </p>
      <h2 class="mt-4 font-sans text-4xl font-semibold tracking-tight text-star-100">
        Privacy-first AI chat.
      </h2>
    </div>
  </section>

  <section id="download" class="flex min-h-screen items-center pt-24">
    <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="font-mono text-sm uppercase tracking-widest text-star-400">
        Download
      </p>
      <h2 class="mt-4 font-sans text-4xl font-semibold tracking-tight text-star-100">
        Get Pinac Workspace.
      </h2>
    </div>
  </section>
</MainLayout>
